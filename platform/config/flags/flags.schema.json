{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OneCurveFeatureFlags",
  "type": "object",
  "required": ["env", "flags"],
  "properties": {
    "env": { "enum": ["dev", "stage", "prod"] },
    "description": { "type": "string" },
    "flags": {
      "type": "object",
      "required": ["payments", "commerce", "features", "ops"],
      "properties": {
        "payments": {
          "type": "object",
          "properties": {
            "razorpay": { "type": "boolean" },
            "razorpay_live_keys": { "type": "boolean" },
            "manual_checkout": { "type": "boolean" },
            "cod": { "type": "boolean" }
          }
        },
        "commerce": {
          "type": "object",
          "properties": {
            "free_shipping_threshold": { "type": "integer" },
            "shipping_flat_inr": { "type": "integer" },
            "prices_tax_inclusive": { "type": "boolean" },
            "gst_line_item": { "type": "boolean" }
          }
        },
        "features": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "ops": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      }
    }
  }
}
