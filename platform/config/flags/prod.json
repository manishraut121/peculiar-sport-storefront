{
  "$schema": "./flags.schema.json",
  "env": "prod",
  "description": "Production — live payments only. Flip with: ./scripts/flip-env.sh prod",
  "flags": {
    "payments": {
      "razorpay": true,
      "razorpay_live_keys": true,
      "manual_checkout": false,
      "cod": false
    },
    "commerce": {
      "free_shipping_threshold": 2999,
      "shipping_flat_inr": 199,
      "prices_tax_inclusive": true,
      "gst_line_item": false
    },
    "features": {
      "ai_assistant": true,
      "smart_search": true,
      "blog": true,
      "customer_accounts": true,
      "reviews": false,
      "wishlist": false,
      "pos": false,
      "bookkeeping": true,
      "maintenance_mode": false
    },
    "ops": {
      "seed_on_boot": false,
      "debug_logging": false,
      "e2e_hooks": false,
      "show_env_badge": false
    }
  }
}
