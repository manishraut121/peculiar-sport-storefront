# OneCurve — DEV environment template
# Apply:  ./scripts/flip-env.sh dev
# Never commit real secrets. Copy values into apps/*/.env after flip.

OC_ENV=dev
OC_FLAGS_FILE=config/flags/dev.json

# Local URLs
STOREFRONT_URL=http://localhost:8000
BACKEND_URL=http://localhost:9000
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000

# Database (local Homebrew / docker)
DATABASE_URL=postgres://localhost/onecurve
REDIS_URL=redis://localhost:6379

# Secrets — generate with: openssl rand -hex 32
JWT_SECRET=dev-jwt-change-me
COOKIE_SECRET=dev-cookie-change-me
AUTH_MFA_ENCRYPTION_KEY=dev-mfa-change-me-32bytesxxxxxx

MEDUSA_ADMIN_EMAIL=admin@onecurve.in
MEDUSA_ADMIN_PASSWORD=dev-admin-change-me

# Publishable key from admin / boot log after first seed
MEDUSA_PUBLISHABLE_KEY=pk_dev_placeholder
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_dev_placeholder
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_REGION=in
NEXT_PUBLIC_OC_ENV=dev

# Payments OFF in dev (manual checkout via flags)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional
GROQ_API_KEY=
ASSISTANT_MODEL=
