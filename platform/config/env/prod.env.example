# OneCurve — PROD environment template
# Apply:  ./scripts/flip-env.sh prod   (requires confirmation)
# Live payments. Manual checkout disabled via flags.

OC_ENV=prod
OC_FLAGS_FILE=config/flags/prod.json

STOREFRONT_URL=https://onecurve.in
BACKEND_URL=https://api.onecurve.in
STORE_CORS=https://onecurve.in,https://www.onecurve.in
ADMIN_CORS=https://api.onecurve.in
AUTH_CORS=https://onecurve.in,https://www.onecurve.in,https://api.onecurve.in

POSTGRES_PASSWORD=CHANGE_ME_PROD_STRONG
DATABASE_URL=postgres://medusa:CHANGE_ME_PROD_STRONG@postgres:5432/medusa
REDIS_URL=redis://redis:6379

JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
COOKIE_SECRET=CHANGE_ME_openssl_rand_hex_32
AUTH_MFA_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

MEDUSA_ADMIN_EMAIL=admin@onecurve.in
MEDUSA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

MEDUSA_PUBLISHABLE_KEY=pk_prod_from_boot_check
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_prod_from_boot_check
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.onecurve.in
NEXT_PUBLIC_BASE_URL=https://onecurve.in
NEXT_PUBLIC_DEFAULT_REGION=in
NEXT_PUBLIC_OC_ENV=prod

# Razorpay LIVE keys (rzp_live_…)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=onecurve-prod
S3_ENDPOINT=
S3_REGION=auto
S3_FILE_URL=https://media.onecurve.in

# Transactional email (order confirmations)
# RESEND_API_KEY= or SMTP_* when wired

GROQ_API_KEY=
ASSISTANT_MODEL=gemma2-9b-it
