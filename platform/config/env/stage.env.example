# OneCurve — STAGE environment template
# Apply:  ./scripts/flip-env.sh stage
# Host: DigitalOcean droplet / Coolify / same docker-compose stack
# Use Razorpay TEST keys only (rzp_test_…)

OC_ENV=stage
OC_FLAGS_FILE=config/flags/stage.json

STOREFRONT_URL=https://stage.onecurve.in
BACKEND_URL=https://api-stage.onecurve.in
STORE_CORS=https://stage.onecurve.in
ADMIN_CORS=https://api-stage.onecurve.in
AUTH_CORS=https://stage.onecurve.in,https://api-stage.onecurve.in

POSTGRES_PASSWORD=CHANGE_ME_STAGE
DATABASE_URL=postgres://medusa:CHANGE_ME_STAGE@postgres:5432/medusa
REDIS_URL=redis://redis:6379

JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
COOKIE_SECRET=CHANGE_ME_openssl_rand_hex_32
AUTH_MFA_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

MEDUSA_ADMIN_EMAIL=admin@onecurve.in
MEDUSA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

MEDUSA_PUBLISHABLE_KEY=pk_stage_from_boot_check
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_stage_from_boot_check
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api-stage.onecurve.in
NEXT_PUBLIC_BASE_URL=https://stage.onecurve.in
NEXT_PUBLIC_DEFAULT_REGION=in
NEXT_PUBLIC_OC_ENV=stage

# Razorpay TEST keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=

# Cloudflare R2 (recommended on stage so uploads persist)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=onecurve-stage
S3_ENDPOINT=
S3_REGION=auto
S3_FILE_URL=

GROQ_API_KEY=
ASSISTANT_MODEL=gemma2-9b-it
