# OneCurve platform — copy to .env and fill in. NEVER commit .env to git.

# Postgres password (any long random string)
POSTGRES_PASSWORD=change-me

# Session/auth secrets — generate each with: openssl rand -hex 32
JWT_SECRET=change-me
COOKIE_SECRET=change-me

# Publishable API key from Medusa admin → Settings → Publishable API Keys
# (safe for browsers; still keep .env out of git)
MEDUSA_PUBLISHABLE_KEY=pk_...

# Public URLs (production)
STOREFRONT_URL=https://onecurve.in
STORE_CORS=https://onecurve.in
ADMIN_CORS=https://admin.onecurve.in
AUTH_CORS=https://onecurve.in,https://admin.onecurve.in

# Razorpay — from dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Cloud image storage (Cloudflare R2 / S3) — for admin-uploaded product photos.
# Leave blank to use local disk (fine locally). On Railway/cloud, set these so
# uploads survive restarts. R2 endpoint: https://<account_id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
# Public URL the browser loads images from (R2 public bucket URL or custom domain)
S3_FILE_URL=
