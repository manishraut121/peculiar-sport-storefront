# Storefront ↔ Medusa CMS (API) wiring
# Copy to .env.local for local dev pointing at the droplet CMS.
#
# CRITICAL for Razorpay stage checkout:
#   NEXT_PUBLIC_OC_ENV=stage  (not dev — dev flags hide razorpay)
#   BACKEND_URL = droplet (not localhost unless backend runs locally with keys)
#   Region must list pp_razorpay_razorpay (run droplet-link-razorpay-sql.sh)

# Public API (CMS backend) — browser + SSR
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://159.89.173.5:9000
MEDUSA_BACKEND_URL=http://159.89.173.5:9000

# From CMS boot / bootstrap output (pk_…)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_afd4cb6af601da39989d1d354c39d7b7916780107413f045d14baa08fa356f90

NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_REGION=in
NEXT_PUBLIC_OC_ENV=stage
NEXT_PUBLIC_OC_FEATURE_FLAGS={"payments":{"razorpay":true,"razorpay_live_keys":false,"manual_checkout":true,"cod":false},"commerce":{"free_shipping_threshold":2999,"shipping_flat_inr":199,"prices_tax_inclusive":true,"gst_line_item":false},"features":{"ai_assistant":true,"smart_search":true,"blog":true,"customer_accounts":true,"reviews":false,"wishlist":false,"pos":false,"bookkeeping":true,"maintenance_mode":false},"ops":{"seed_on_boot":false,"debug_logging":true,"e2e_hooks":true,"show_env_badge":true}}

# How fast Admin edits appear on the shop (seconds). Stage: 15. Prod: 60.
CATALOG_REVALIDATE_SECONDS=15

# Optional: instant cache bust after big CMS edits
# curl -X POST http://localhost:8000/api/revalidate -H "x-revalidate-secret: change-me"
REVALIDATE_SECRET=change-me-stage

# next/image hosts for product photos served by the API
NEXT_IMAGE_HOSTS=159.89.173.5

# Optional fallback if payment session data lacks keyId (prefer session keyId)
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx

